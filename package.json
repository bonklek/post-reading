{
  "name": "post-reading",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Browser extension for read-aloud controls on X/Twitter posts.",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "pnpm run build:chromium && pnpm run build:edge && pnpm run build:brave && pnpm run build:vivaldi && pnpm run build:opera && pnpm run build:firefox",
    "build:chromium": "node scripts/build-post-reading.mjs --target=chromium",
    "build:edge": "node scripts/build-post-reading.mjs --target=edge",
    "build:brave": "node scripts/build-post-reading.mjs --target=brave",
    "build:vivaldi": "node scripts/build-post-reading.mjs --target=vivaldi",
    "build:opera": "node scripts/build-post-reading.mjs --target=opera",
    "build:firefox": "node scripts/build-post-reading.mjs --target=firefox",
    "dev": "node scripts/build-post-reading.mjs --target=chromium --watch",
    "dev:edge": "node scripts/build-post-reading.mjs --target=edge --watch",
    "dev:brave": "node scripts/build-post-reading.mjs --target=brave --watch",
    "dev:vivaldi": "node scripts/build-post-reading.mjs --target=vivaldi --watch",
    "dev:opera": "node scripts/build-post-reading.mjs --target=opera --watch",
    "dev:firefox": "node scripts/build-post-reading.mjs --target=firefox --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.29",
    "@types/node": "^24.10.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.7.0"
}
